[user]
	name = Matteo Bertamini
	email = matteo@bertamini.net
	signingkey = 1D9B2D75EB0FD6A323761D217CD5CEF29690E45E

[alias]
	st = status
	c = !git add -A && git commit
	reset-permissions = !git diff -p -R | grep -E \"^(diff|(old|new) mode)\" --color=newer | git apply
[core]
	excludefile = ~/.gitignore_global
[commit]
	gpgsign = true
[credential]
        helper = cache --timeout=86400
[includeif "gitdir:~/Code/Work/"]
	path = ~/.gitconfig-work

[tag]
	gpgsign = true
